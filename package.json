{
    "name": "dexcom-desktop-application",
    "productName": "Dexcom",
    "version": "1.0.0",
    "description": "Dexcom G6 & G7 readings on the computer",
    "main": ".vite/build/main.js",
    "scripts": {
        "start": "electron-forge start",
        "build:python": "cd python && pip install -r requirements.txt && pyinstaller --onefile --name dexcom dexcom_server/__main__.py && cp dist/dexcom ../src/dexcom",
        "package": "npm run build:python && electron-forge package",
        "make": "npm run build:python && electron-forge make",
        "publish": "electron-forge publish",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.2",
        "@electron-forge/maker-deb": "^7.11.2",
        "@electron-forge/maker-rpm": "^7.11.2",
        "@electron-forge/maker-squirrel": "^7.11.2",
        "@electron-forge/maker-zip": "^7.11.2",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
        "@electron-forge/plugin-fuses": "^7.11.2",
        "@electron-forge/plugin-vite": "^7.11.2",
        "@electron/fuses": "^1.8.0",
        "@tailwindcss/vite": "^4.3.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/ws": "^8.18.1",
        "autoprefixer": "^10.5.1",
        "electron": "^42.5.0",
        "eslint": "^10.5.0",
        "postcss": "^8.5.15",
        "rollup-plugin-copy": "^3.5.0",
        "tailwindcss": "^4.3.1",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0"
    },
    "keywords": [],
    "author": "Matthew Blam",
    "license": "MIT",
    "dependencies": {
        "clsx": "^2.1.1",
        "electron-squirrel-startup": "^1.0.1",
        "inter-ui": "^4.1.1",
        "lucide-react": "^1.21.0",
        "motion": "^12.41.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "recharts": "^3.9.0",
        "tailwind-merge": "^3.6.0",
        "ws": "^8.21.0"
    }
}
